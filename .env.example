# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── SAP Credentials ──────────────────────────────────────
SAP_USERNAME=your_sap_user
SAP_PASSWORD=your_sap_password
SAP_S4_BASE_URL=https://your-sap-api-url
SAP_CLIENT=100
SAP_USERNAME_FORMAT=user

# ─── Fernet (encrypt/decrypt SAP passwords in DB) ─────────
FERNET_KEY=your-fernet-key

# ─── Pinecone (vector search) ─────────────────────────────
PINECONE_KEY=your-pinecone-key

# ─── Database (leave empty if no DB) ──────────────────────
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_VECTOR_NAME=
