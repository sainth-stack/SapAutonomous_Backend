# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── SAP S/4HANA OData credentials ───────────────────────
SAP_USERNAME=your_sap_user
SAP_PASSWORD=your_sap_password
# Base URL of your SAP system (no trailing slash)
# e.g. https://my-system.example.com or http://10.0.0.1:8000
SAP_S4_BASE_URL=https://your-sap-api-url
SAP_CLIENT=100
# "user" → Basic auth as <username>
# "user@client" → Basic auth as <username>@<client>
SAP_USERNAME_FORMAT=user
# OData path prefix — must match your SAP system layout:
#   Standard SAP Gateway  : /sap/opu/odata/sap   ← default
#   SAP API Management    : /odata
#   Custom proxy, no prefix: (leave empty)
SAP_ODATA_PREFIX=/sap/opu/odata/sap

# ─── Optional overrides ────────────────────────────────────
# OpenAI model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# SAP BTP / Batch external API URLs (used by /api/sap/query-external)
# SAP_BTP_API=https://...
# SAP_BATCH_API=https://...
# Server port (default: 4001)
# PORT=4001
# Fernet key for encrypting stored SAP credentials (configuration API)
# FERNET_KEY=...
# Database URL (defaults to sqlite:///./sapautonomous.db)
# DATABASE_URL=sqlite:///./sapautonomous.db
